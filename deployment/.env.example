# ============================================================
# INFOX — Environment Variable Reference
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ============================================================

# ── Server ───────────────────────────────────────────────────
PORT=8080
NODE_ENV=production

# ── Database ─────────────────────────────────────────────────
# PostgreSQL connection string. Examples:
#   Replit:  (auto-provisioned — check Secrets tab)
#   Railway: postgresql://user:pass@host.railway.internal:5432/railway
#   Render:  postgresql://user:pass@host.render.com:5432/dbname
#   Local:   postgresql://postgres:password@localhost:5432/infox
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── AI Provider ──────────────────────────────────────────────
# Options: github | openai | gemini
AI_PROVIDER=github

# GitHub Models (default — free via GitHub Marketplace)
GITHUB_TOKEN=ghp_xxxxxxxxxxxx

# OpenAI (paid)
# OPENAI_API_KEY=sk-xxxxxxxxxxxx

# Google Gemini (free tier available)
# GEMINI_API_KEY=AIzaxxxxxxxxxxxx

# ── Telegram Delivery ────────────────────────────────────────
# Get these from @BotFather on Telegram.
# Optional — app works without them; enables scheduled delivery.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Scheduler ────────────────────────────────────────────────
# IANA timezone for morning (07:00) and evening (18:00) briefings.
SCHEDULER_TIMEZONE=Asia/Bangkok
