# ============================================================
# INFOX — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# ── Server (Required) ─────────────────────────────────────
PORT=8080
NODE_ENV=production

# ── Database (Required) ───────────────────────────────────
# Get from Neon: https://neon.tech → New Project → Connection string
# Get from Railway: Add PostgreSQL plugin → Variables tab
# Get from Supabase: Project Settings → Database → Connection string
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# ── Auth (Required) ───────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-64-char-random-secret-here

# ── AI Provider (Pick one) ────────────────────────────────
# "github" = GitHub Models (free, recommended)
# "openai" = OpenAI API
# "gemini" = Google Gemini
AI_PROVIDER=github

# GitHub Models (free with GitHub account)
# Get from: https://github.com/settings/tokens → Generate new token (classic) → no scopes needed
GITHUB_TOKEN=ghp_your_github_token_here

# OpenAI (if using AI_PROVIDER=openai)
# OPENAI_API_KEY=sk-...

# Google Gemini (if using AI_PROVIDER=gemini)
# GEMINI_API_KEY=AIza...

# ── Telegram Delivery (Optional) ─────────────────────────
# Create bot: https://t.me/BotFather → /newbot
# Get chat ID: send message to bot, then https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Scheduler (Optional) ──────────────────────────────────
# IANA timezone: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
SCHEDULER_TIMEZONE=Asia/Bangkok

# ── Frontend URL (Optional but recommended in production) ─
# The URL where your frontend is hosted (Vercel URL or custom domain)
# Used for CORS and Google OAuth redirects
FRONTEND_URL=https://your-app.vercel.app

# ── Google OAuth (Optional) ───────────────────────────────
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI: https://your-backend.railway.app/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Admin Access (Optional) ───────────────────────────────
# Comma-separated emails that get admin role on register/login
ADMIN_EMAILS=your@email.com

# ── PromptPay QR (Optional) ──────────────────────────────
PROMPTPAY_PHONE_NUMBER=

# ── Twitter/X Trends (Optional) ───────────────────────────
# Get from: https://developer.twitter.com
TWITTER_BEARER_TOKEN=

# ── YouTube Trends (Optional) ─────────────────────────────
# Get from: https://console.cloud.google.com → YouTube Data API v3
YOUTUBE_API_KEY=
